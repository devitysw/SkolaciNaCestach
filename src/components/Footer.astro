---
import logo from "../assets/logo-text.svg";
import bg from "../assets/bg-green.svg";
import fb from "../assets/fb-logo.svg";
import ig from "../assets/ig-logo.svg";
---
<div class="w-full bg-auto bg-repeat bg-top pt-12 pb-4 text-bg" style={{ backgroundImage: `url('${bg.src}')` }} >
    <div class="content">
        <div class="w-full grid grid-cols-1 md:grid-cols-5 gap-2 text-xs lg:text-sm" >
            <div class="md:col-span-2">
                <img
                    src={logo.src}
                    alt="Logo školy"
                    class="h-16 mx-auto md:ml-0"
                    loading="lazy"
                />
                <p class="mt-4 w-5/6 md:w-2/3 mx-auto md:ml-0 text-center md:text-left">
                    Našim cieľom je, aby deti spoznali krásy Slovenska, zamilovali si prírodu a pohyb. <br>
                    Ponúkame kvalitné ubytovanie, chutnú stravu a aktivity, ktoré zabavia aj obohatia školákov. <br>
                    Ku každej škole pristupujeme individuálne a pobyt prispôsobíme jej potrebám.
                </p>
                <div class="flex flex-row space-x-4 mt-4 w-max mx-auto md:ml-0">
                    <div class="w-8 h-8 bg-lightGreen text-center flex items-stretch rounded-full">
                        <a class="self-center w-max mx-auto"
                            href="https://zsmssvgorazd.edupage.org/"
                            target="_blank" >
                            <img
                                src={ig.src}
                                alt="Instagram logo"
                                class="h-8 w-8 mx-auto"
                                loading="lazy"
                            />
                        </a>
                    </div>
                    <div class="w-8 h-8 bg-lightGreen text-center flex items-stretch rounded-full" >
                        <a
                            class="self-center w-max mx-auto"
                            href="https://www.facebook.com/share/1BMwDkWjm8/"
                            target="_blank" >
                            <img
                                src={fb.src}
                                alt="Instagram logo"
                                class="h-8 w-8 mx-auto"
                                loading="lazy"
                            />
                        </a>
                    </div>
                </div>
            </div>
            <div class="md:col-span-3 grid grid-cols-1 sm:grid-cols-3 sm:gap-2 mt-4 md:mt-0 w-full" >
                <div class="w-max mx-auto md:ml-0 mt-8 sm:mt-0">
                    <h1 class="text-center sm:text-left">Dôležité odkazy</h1>
                    <div class="flex flex-col gap-2 mt-4">
                        <a href="https://zsmssvgorazd.edupage.org/" target="_blank" class="animated-underline w-max mx-auto sm:ml-0" >Edupage</a>
                        <a href=`${import.meta.env.BASE_URL}o-nas/rada-rodicov/` class="animated-underline w-max mx-auto sm:ml-0" >Rada rodičov</a >
                    </div>
                </div>
                <div class="w-max mx-auto md:ml-0 mt-8 sm:mt-0">
                    <h1 class="text-center sm:text-left">Informácie</h1>
                    <div class="flex flex-col gap-2 mt-4">
                        <a
                            href=`${import.meta.env.BASE_URL}aktuality/${new Date().getFullYear().toString()}/`
                            class="animated-underline w-max mx-auto sm:ml-0"
                            >Aktuality</a >
                        <a
                            href=`${import.meta.env.BASE_URL}kalendar/`
                            class="animated-underline w-max mx-auto sm:ml-0"
                            >Kalendár udalostí</a >
                        <a
                            href=`${import.meta.env.BASE_URL}prazdniny/`
                            class="animated-underline w-max mx-auto sm:ml-0"
                            >Prázdniny</a >
                        <a
                            href=`${import.meta.env.BASE_URL}zoznam-pomocok/`
                            class="animated-underline w-max mx-auto sm:ml-0"
                            >Zoznam pomôcok</a >
                    </div>
                </div>
                <div class="w-max mx-auto md:ml-0 mt-8 sm:mt-0">
                    <h1 class="text-center sm:text-left">Kontakt</h1>
                    <div class="mt-4 w-full text-center sm:text-left">
                        CZŠ s MŠ sv. Gorazda <br />
                        Juhoslovanská 2 <br />
                        040 13 Košice <br />
                    </div>
                    <a
                        href=`${import.meta.env.BASE_URL}kontakt/`
                        class="animated-underline w-max mx-auto sm:ml-0 mt-2"
                    >Kontakt</a>
                </div>
            </div>
        </div>
        <div
            class="w-full flex flex-col lg:flex-row justify-center lg:justify-between text-[0.5rem] lg:text-xs self-center text-center mt-4"
        >
            <div>© 2023 Copyright CZŠ s MŠ Juhoslovanská 2, Košice</div>
            <div>
                Vytvorené s 💙 pre školu od <a
                    href="https://devity.sk/"
                    target="_blank"
                    class="animated-underline w-max">DEVITY Software</a
                >&nbsp;&nbsp;&nbsp;&nbsp;|&nbsp;&nbsp;&nbsp;&nbsp;Forografie a
                ilustrácie: archív školy a <a
                    href=`${import.meta.env.BASE_URL}credits/`
                    class="animated-underline w-max mx-auto sm:ml-0">Freepik</a
                > | <a
                    href=`${import.meta.env.BASE_URL}admin/index.html`
                    class="animated-underline w-max mx-auto sm:ml-0">Admin</a
                >
            </div>
        </div>
    </div>
</div>