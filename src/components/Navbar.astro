---
import logo from "../assets/logo.svg";
---

<nav id="nav" class="bg-white shadow-md sticky top-0 z-50 transition-all duration-300">
  <div class="content">
    <div class="flex items-center justify-between h-20">
      
      <div class="shrink-0 flex items-center">
        <a href=`${import.meta.env.BASE_URL}`>
            <img src={logo.src} alt="Logo skoly" class="h-8 sm:h-10 md:h-12 lg:h-14 self-center" loading="eager">
        </a>
      </div>

      <div class="hidden lg:flex items-center space-x-8">
        
        <div class="flex items-center space-x-2">
          
          <div class="group relative">
            <button class="flex items-center gap-1 px-4 py-2 text-slate-800 font-medium rounded-md hover:bg-secondary hover:text-primary transition-colors">
              Pobyty
              <svg class="w-4 h-4 transform transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            <div class="absolute left-0 mt-0 w-48 bg-white rounded-md border border-primary shadow-xl opacity-0 invisible translate-y-2 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 transition-all duration-200 z-50">
              <a href={`${import.meta.env.BASE_URL}pobyty/?filter=priroda`} class="block px-4 py-3 text-sm text-slate-800 hover:bg-secondary rounded-t-md">Školy v prírode</a>
              <a href={`${import.meta.env.BASE_URL}pobyty/?filter=lyziarske`} class="block px-4 py-3 text-sm text-slate-800 hover:bg-secondary">Lyžiarske kurzy</a>
              <a href={`${import.meta.env.BASE_URL}pobyty/?filter=turisticky`} class="block px-4 py-3 text-sm text-slate-800 hover:bg-secondary rounded-b-md">Turistické kurzy</a>
            </div>
          </div>

          <div class="group relative">
            <button class="flex items-center gap-1 px-4 py-2 text-slate-800 font-medium rounded-md hover:bg-secondary transition-colors">
              Služby
              <svg class="w-4 h-4 transform transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            <div class="absolute left-0 mt-0 w-48 bg-white rounded-md shadow-xl opacity-0 invisible translate-y-2 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 transition-all duration-200 z-50 border border-primary">
              <a href={`${import.meta.env.BASE_URL}sluzby/animacny-program/`} class="block px-4 py-3 text-sm text-slate-800 hover:bg-secondary rounded-t-md">Animačný program</a>
              <a href={`${import.meta.env.BASE_URL}sluzby/skolkariq/`} class="block px-4 py-3 text-sm text-slate-800 hover:bg-secondary rounded-b-md">ŠkôlkarIq</a>
              <a href={`${import.meta.env.BASE_URL}sluzby/saso/`} class="block px-4 py-3 text-sm text-slate-800 hover:bg-secondary rounded-b-md">Šašo</a>
            </div>
          </div>

          <div class="group relative">
            <button class="flex items-center gap-1 px-4 py-2 text-slate-800 font-medium rounded-md hover:bg-secondary transition-colors">
              Informácie
              <svg class="w-4 h-4 transform transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            <div class="absolute left-0 mt-0 w-48 bg-white rounded-md shadow-xl opacity-0 invisible translate-y-2 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 transition-all duration-200 z-50 border border-primary">
              <a href={`${import.meta.env.BASE_URL}informacie/zakladne-informacie/`} class="block px-4 py-3 text-sm text-slate-800 hover:bg-secondary rounded-t-md">Základné informácie</a>
              <a href={`${import.meta.env.BASE_URL}o-nas/`} class="block px-4 py-3 text-sm text-slate-800 hover:bg-secondary rounded-b-md">Kto sme?</a>
            </div>
          </div>

          <a href={`${import.meta.env.BASE_URL}kontakt/`} class="px-4 py-2 text-slate-800 font-medium rounded-md hover:bg-secondary transition-colors">Kontakt</a>
        </div>

      </div>

      <div class="flex flex-row space-x-2">
        <div class="hidden sm:flex flex-row items-center p-2 border border-primary xl:border-slate-200 xl:border-0 xl:border-l rounded-lg xl:rounded-none">
            <div class="xl:hidden flex items-center">
                <span class="material-symbols-rounded text-primary">
                    call
                </span>
            </div>

            <div class="flex flex-col items-center justify-center gap-0.5 xl:p-0 xl:pl-2 text-sm xl:flex-row xl:gap-4 h-auto xl:h-full ">
    
                <a href="tel:+421907205144" class="flex items-center justify-center xl:flex-col text-center xl:text-right group/phone h-full xl:justify-center">
                    <span class="hidden xl:inline text-xs text-slate-400 font-medium uppercase tracking-wider">Zavolajte nám</span>
                    <span class="text-slate-800 font-bold group-hover/phone:text-primary transition-colors text-xs sm:text-sm xl:text-base">+421 907 205 144</span>
                </a>

                <div class="hidden min-[425px]:flex flex-col text-center border-slate-100 w-full xl:w-auto xl:text-left xl:border-l-2 xl:border-primary xl:pl-3 h-full xl:justify-center">
                    <span class="hidden xl:inline text-xs text-slate-400 font-medium uppercase tracking-wider">Otváracie hodiny</span>
                    <span class="text-slate-500 font-medium text-[11px] sm:text-xs xl:text-sm xl:text-slate-600 xl:font-semibold">Po - Pia: 7:30 - 16:00</span>
                </div>
            </div>
        </div>

        <div class="lg:hidden flex items-center">
            <button id="menu-btn" class="p-2 rounded-md text-slate-600 hover:bg-secondary hover:text-primary focus:outline-none transition-colors" aria-label="Toggle Menu">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            </button>
        </div>
      </div>

    </div>
  </div>

  <div id="menu" class="hidden lg:hidden bg-white border-t border-slate-100 absolute top-20 left-0 w-full shadow-lg z-40 max-h-[calc(100vh-5rem)] overflow-y-auto">
    <div class="px-4 pt-4 pb-6 space-y-3">
      
      <div>
        <button data-mobile-dropdown-target="mob-1" class="w-full flex justify-between items-center py-2 text-slate-700 font-semibold border-b border-slate-50">
          Pobyty
          <svg class="arrow-icon w-4 h-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </button>
        <div id="mob-1" class="hidden bg-secondary/40 pl-4 rounded-md mt-1">
          <a href={`${import.meta.env.BASE_URL}pobyty/?filter=priroda`} class="block py-2.5 text-sm text-slate-600 font-medium">Školy v prírode</a>
          <a href={`${import.meta.env.BASE_URL}pobyty/?filter=lyziarske`} class="block py-2.5 text-sm text-slate-600 font-medium">Lyžiarske kurzy</a>
          <a href={`${import.meta.env.BASE_URL}pobyty/?filter=turisticky`} class="block py-2.5 text-sm text-slate-600 font-medium">Turistické kurzy</a>
        </div>
      </div>

      <div>
        <button data-mobile-dropdown-target="mob-2" class="w-full flex justify-between items-center py-2 text-slate-700 font-semibold border-b border-slate-50">
          Služby 
          <svg class="arrow-icon w-4 h-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </button>
        <div id="mob-2" class="hidden bg-secondary/40 pl-4 rounded-md mt-1">
          <a href={`${import.meta.env.BASE_URL}sluzby/animacny-program/`} class="block py-2.5 text-sm text-slate-600 font-medium">Animačný program</a>
          <a href={`${import.meta.env.BASE_URL}sluzby/skolkariq/`} class="block py-2.5 text-sm text-slate-600 font-medium">ŠkôlkarIq</a>
          <a href={`${import.meta.env.BASE_URL}sluzby/saso/`} class="block py-2.5 text-sm text-slate-600 font-medium">Šašo</a>
        </div>
      </div>

      <div>
        <button data-mobile-dropdown-target="mob-3" class="w-full flex justify-between items-center py-2 text-slate-700 font-semibold border-b border-slate-50">
          Informácie 
          <svg class="arrow-icon w-4 h-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </button>
        <div id="mob-3" class="hidden bg-secondary/40 pl-4 rounded-md mt-1">
          <a href={`${import.meta.env.BASE_URL}informacie/zakladne-informacie/`} class="block py-2.5 text-sm text-slate-600 font-medium">Základné informácie</a>
          <a href={`${import.meta.env.BASE_URL}o-nas/`} class="block py-2.5 text-sm text-slate-600 font-medium">Kto sme?</a>
        </div>
      </div>

      <a href={`${import.meta.env.BASE_URL}kontakt/`} class="block py-2 text-slate-700 font-semibold border-b border-slate-50">Kontakt</a>

      <div class="mt-6 pt-6 border-t border-slate-100 grid grid-cols-2 gap-4">
        <a href="tel:+421907205144" class="bg-secondary/60 p-3 rounded-lg flex flex-col">
          <span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">Zavolajte nám</span>
          <span class="text-sm text-text font-bold mt-0.5">+421 907 205 144</span>
        </a>
        <div class="bg-slate-50 p-3 rounded-lg flex flex-col border-l-2 border-primary">
          <span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">Otvorené</span>
          <span class="text-xs text-slate-600 font-bold mt-0.5">Po - Pia: 7:30 - 16</span>
        </div>
      </div>

    </div>
  </div>
</nav>

<script>
  // DOM selectors for core mobile structures
  const btn = document.getElementById('menu-btn');
  const nav = document.getElementById('menu');

  function toggleMobileMenu() {
    btn.classList.toggle('open');
    nav.classList.toggle('hidden');
    
    // REMOVED the dynamicOffset calculation that pushed the header down.
    // The mobile menu drawer is absolute and positioned at 'top-20' (h-20 of navbar),
    // so it will naturally drop down cleanly right under your logo.
  }

  // Bind container button clicks safely inside Astro scope
  if (btn && nav) {
    btn.addEventListener('click', toggleMobileMenu);
  }

  // Dynamic targeting loops for declarative mobile accordion targets
  const mobileDropdownButtons = document.querySelectorAll('[data-mobile-dropdown-target]');

  mobileDropdownButtons.forEach(button => {
    button.addEventListener('click', () => {
      const targetId = button.getAttribute('data-mobile-dropdown-target');
      const targetDropdown = document.getElementById(targetId);
      const arrowIcon = button.querySelector('.arrow-icon');

      if (targetDropdown) {
        targetDropdown.classList.toggle('hidden');
      }
      if (arrowIcon) {
        arrowIcon.classList.toggle('rotate-180');
      }
    });
  });
</script>