---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import TripCard from '../components/TripCard.astro';
import ProgramCard from '../components/ProgramCard.astro';
import { trips, extraPrograms } from '../data/trips';

const featuredTrips = trips.slice(0, 3);

const regions = [
	{ name: 'Banská Belá', area: 'Stredné Slovensko' },
	{ name: 'Liptovský Hrádok', area: 'Vysoké a Nízke Tatry' },
	{ name: 'Košice a okolie', area: 'Východné Slovensko' },
];

const benefits = [
	{ icon: 'account_balance_wallet', label: 'Transparentný účet' },
	{ icon: 'directions_bus', label: 'Doprava' },
	{ icon: 'card_giftcard', label: 'Bonus pre triedy' },
	{ icon: 'verified_user', label: 'Poistenie' },
	{ icon: 'hiking', label: 'Skúsený sprievodca' },
	{ icon: 'checklist', label: 'Overené zariadenia' },
];
---

<Layout title="Domov">
	<Hero
		title="Zážitkové učenie mimo školských lavíc"
		subtitle="Kompletná organizácia školských výletov a pobytov s individuálnym prístupom."
		cta={{ text: 'Ponuka výletov', href: '/pobyty/' }}
		images={[
			'https://images.unsplash.com/photo-1503919545889-aef636e10ad4?w=500&h=400&fit=crop',
			'https://images.unsplash.com/photo-1471958680802-1345a694ba6d?w=400&h=300&fit=crop',
			'https://images.unsplash.com/photo-1503457574465-32a366916963?w=400&h=300&fit=crop'
		]}
		imageAlt="Deti na školskom výlete"
	/>

	<!-- Regions Section -->
	<section class="py-16 bg-white bg-topo">
		<div class="content">
			<SectionHeading
				title="Kde sa začne vaše dobrodružstvo?"
				subtitle="Pozrite si detaily našich preverených hotelov a stredísk."
			/>

			<div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-3xl mx-auto">
				{regions.map(region => (
					<div class="card p-6 text-center">
						<span class="material-symbols-rounded text-tint text-4xl mb-2 block">location_on</span>
						<h3 class="text-primary">{region.name}</h3>
						<p class="text-sm text-text/70">{region.area}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Featured Trips Section -->
	<section class="py-16 bg-bg">
		<div class="content">
			<SectionHeading
				title="Vyberte si ten pravý výlet"
				subtitle="Čakajú na vás zariadenia vhodné na školy v prírode a lyžiarske kurzy."
			/>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				{featuredTrips.map(trip => (
					<TripCard
						id={trip.id}
						name={trip.name}
						location={trip.location}
						pricePerDay={trip.pricePerDay}
						originalPrice={trip.originalPrice}
						image={trip.image}
						dates={trip.dates}
					/>
				))}
			</div>

			<div class="text-center mt-10">
				<a href="/pobyty/" class="btn-secondary">
					Pozrieť všetky pobyty
				</a>
			</div>
		</div>
	</section>

	<!-- Info Section -->
	<section class="section-green">
		<div class="content grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
			<div>
				<h2 class="text-bg mb-1">Sme tu pre radosť školákov a pohodu pedagógov</h2>
				<div class="underline-accent bg-tint"></div>
				<p class="text-bg/90">
					Našim cieľom je, aby deti spoznali krásy Slovenska, zamilovali si prírodu a pohyb. Ponúkame kvalitné ubytovanie, chutnú stravu a aktivity, ktoré zabavia aj obohatia školákov. Ku každej škole pristupujeme individuálne a pobyt prispôsobíme jej potrebám.
				</p>
			</div>
			<div>
				<img
					src="https://images.unsplash.com/photo-1427504494785-cdec0f72afa5?w=600&h=450&fit=crop"
					alt="Školáci na výlete"
					class="rounded-xl shadow-lg w-full h-64 md:h-80 object-cover"
					loading="lazy"
				/>
			</div>
		</div>
	</section>

	<!-- Programs Section -->
	<section class="py-16 bg-bg">
		<div class="content">
			<SectionHeading
				title="Programy na výber"
				subtitle="Vyberte si z našej ponuky aktivít, ktoré deti obohatia o zábavu a zážitky navyše."
			/>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				{extraPrograms.map(program => (
					<ProgramCard
						name={program.name}
						description={program.shortDescription}
						image={program.image}
						link={program.link}
					/>
				))}
			</div>
		</div>
	</section>

	<!-- Peace of mind Section -->
	<section class="section-green">
		<div class="content grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
			<div>
				<h2 class="text-bg mb-1">Váš pobyt hladko a bez starostí</h2>
				<div class="underline-accent bg-tint"></div>
				<p class="text-bg/90 mb-6">
					Zálezí nám na vašej pohode, a preto zabezpečujeme plný servis spojený s výletom. Od zabezpečenia dopravy až po starostlivosť o deti počas celej cesty.
				</p>
				<a href="/informacie/zakladne-informacie/" class="btn-primary">Viac o výhodách</a>
			</div>
			<div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
				{benefits.map(benefit => (
					<div class="bg-white/10 rounded-lg p-4 text-center">
						<span class="material-symbols-rounded text-tint text-3xl mb-2 block">{benefit.icon}</span>
						<p class="text-xs text-bg/90 font-semibold">{benefit.label}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Newsletter Section -->
	<section class="py-16 bg-bg">
		<div class="content max-w-xl">
			<SectionHeading
				title="Nenechajte si nič ujsť"
				subtitle="Prihláste sa na odber noviniek, aby ste sa dozvedeli o nových ponukách a výhodných výletoch ako prví."
			/>

			<form class="flex flex-col sm:flex-row gap-3">
				<input
					type="email"
					placeholder="Vaša e-mailová adresa"
					required
					class="flex-grow px-4 py-3 border border-secondary rounded-full focus:outline-none focus:ring-2 focus:ring-tint"
				/>
				<button type="submit" class="btn-primary whitespace-nowrap">
					Prihlásiť sa
				</button>
			</form>
		</div>
	</section>
</Layout>
