---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import TripCard from '../components/TripCard.astro';
import ProgramCard from '../components/ProgramCard.astro';
import SlovakiaMap from '../components/SlovakiaMap.astro';
import { trips, extraPrograms } from '../data/trips';
import heroPhoto from '../assets/hero-photo.webp';
import BenefitsCard from '../components/BenefitsCard.astro';

import bgMap from "../assets/bg/map.svg";
import bgtrips from "../assets/bg/trips.svg";
import bgabout from "../assets/bg/about.svg";
import mapDecor from "../assets/map.png";
import decor from "../assets/decor-bush.svg";
import bush2 from "../assets/bush2.svg";
import mountains from "../assets/mountains.svg";
import decor2 from "../assets/decor-arrows.svg";
import kids from "../assets/kids.png";
import bus from "../assets/bus.svg";
import insurance from "../assets/insurance.svg";
import medic from "../assets/medic.svg";
import present from "../assets/present.svg";
import ski from "../assets/ski.svg";
import teacher from "../assets/teacher.svg";
import bghero from "../assets/bg/hero.svg";

import { map } from 'astro:schema';

const featuredTrips = trips.slice(0, 6);
---

<Layout
	title="Domov"
	description="Školáci na cesty organizuje školy v prírode a lyžiarske kurzy pre základné školy na Slovensku. Kvalitné ubytovanie, strava a individuálny prístup ku každej triede."
>
	<div class="bg-bg relative overflow-hidden bg-cover bg-center bg-no-repeat" style={{ backgroundImage: `url('${bghero.src}')` }}>	
		<Hero
			title="Zážitkové učenie mimo školských lavíc"
			subtitle="Kompletná organizácia školských výletov a pobytov s individuálnym prístupom."
			cta={{ text: 'Ponuka výletov', href: '/pobyty/' }}
			graphic={heroPhoto.src}
			imageAlt="Deti na školskom výlete"
		/>
	</div>

	<!-- Regions Section -->
	<section class="py-16 sm:py-32 bg-contain bg-primary bg-repeat bg-center relative" style={{ backgroundImage: `url('${bgMap.src}')` }}>
		<div class="content">
			<SectionHeading
				title="Kde sa začne vaše dobrodružstvo?"
				subtitle="Kliknite na značku na mape a pozrite si detaily nášho pobytu."
				light
			/>

			<SlovakiaMap />
		</div>
		<img src={mapDecor.src} alt="Ilustrácia mapy" class="w-18 sm:w-24 md:w-48 h-auto absolute bottom-0 right-4 sm:right-8 translate-y-1/2">
	</section>

	<!-- Featured Trips Section -->
	<section class="py-16 sm:py-32 bg-contain bg-repeat bg-center relative" style={{ backgroundImage: `url('${bgtrips.src}')` }}>
		<div class="content">
			<SectionHeading
				title="Vyberte si ten pravý výlet"
				subtitle="Čakajú na vás zariadenia vhodné na školy v prírode a lyžiarske kurzy."
			/>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				{featuredTrips.map(trip => (
					<TripCard
						id={trip.id}
						name={trip.name}
						location={trip.location}
						pricePerDay={trip.pricePerDay}
						originalPrice={trip.originalPrice}
						image={trip.image}
						dates={trip.dates}
					/>
				))}
			</div>

			<div class="text-center mt-10">
				<a href="/pobyty/" class="btn-secondary">
					Pozrieť všetky pobyty
				</a>
			</div>
		</div>
		<img src={decor.src} alt="" class="hidden sm:block sm:h-24 md:h-32 w-auto absolute -bottom-2 -left-2">
		<img src={decor2.src} alt="" class="hidden sm:block sm:h-24 md:h-32 w-auto absolute -bottom-2 right-0">
	</section>

	<!-- Info Section -->
	<section class="py-16 sm:py-32 bg-cover bg-primary bg-no-repeat bg-center relative" style={{ backgroundImage: `url('${bgabout.src}')` }}>
		<div class="content grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
			<SectionHeading
				title="Sme tu pre radosť školákov a pohodu pedagógov"
				subtitle="Pokračujeme v tradícii CK Detská rekreácia, pozorovali sme Vaše  potreby, počúvali Vaše priania, k tomu pridávame niečo vlastné -  zaujímavé aktivity ako jedinečný herný koncept Einstein v prírode s občianskym združením ŠkôlkarIQ, či ozajstný zážitok - show s naším  fantastickým Šašom, ktorý rozosmeje deti aj dospelých. Ponúkame Vám aj  možnosť animácií s našimi skvelými animátormi."
				align='left'
				light
			/>
			<div>
				<img
					src={kids.src}
					alt="Školáci na výlete"
					class="rounded-xl shadow-lg w-3/4 mx-auto h-64 md:h-80 object-cover"
					loading="lazy"
				/>
			</div>
		</div>
	</section>

	<!-- Programs Section -->
	<section class="py-16 sm:py-32 bg-contain bg-repeat bg-center relative" style={{ backgroundImage: `url('${bgtrips.src}')` }}>
		<div class="content">
			<SectionHeading
				title="Programy na výber"
				subtitle="Vyberte si z našej ponuky aktivít, ktoré deti obohatia o zábavu a zážitky navyše."
			/>

			<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
				{extraPrograms.map(program => (
					<ProgramCard
						name={program.name}
						description={program.description}
						image={program.image}
						link={program.link}
					/>
				))}
			</div>
		</div>
		<img src={mountains.src} alt="" class="hidden sm:block sm:h-24 md:h-32 w-auto absolute -bottom-2 -left-2">
		<img src={bush2.src} alt="" class="hidden sm:block sm:h-24 md:h-32 w-auto absolute -bottom-2 right-0">
	</section>

	<!-- Peace of mind Section -->
	<section class="py-16 sm:py-32 bg-cover bg-primary bg-no-repeat bg-center relative" style={{ backgroundImage: `url('${bgabout.src}')` }}>
		<div class="content grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
			<div class="flex flex-col space-y-4">
				<SectionHeading
					title="Váš pobyt hladko a bez starostí"
					subtitle="Záleží nám na Vašej pohode, a preto zabezpečujeme plný servis spojený s Vašim výletom. Od zdravotníka, cez dopravu na a z miesta výletu až po výhodné ceny pri vyššom počte žiakov."
					align='left'
					light
				/>
				<a href="/informacie/zakladne-informacie/" class="btn-primary w-max mx-auto md:mx-0">Viac o výhodách</a>
			</div>
			<div class="hidden md:grid grid-cols-2 sm:grid-cols-3 gap-4">
				<BenefitsCard label="pedagogický dozor" icon={teacher.src} />
				<BenefitsCard label="doprava" icon={bus.src} />
				<BenefitsCard label="bonus pre školy" icon={present.src} />
				<BenefitsCard label="zdravotník" icon={medic.src} />
				<BenefitsCard label="lyžiarske kurzy" icon={ski.src} />
				<BenefitsCard label="poistenie" icon={insurance.src} />
			</div>
		</div>
	</section>

	<!-- Newsletter Section -->
	<section class="py-16 bg-bg">
		<div class="content max-w-xl flex flex-col items-center">
			<SectionHeading
				title="Nenechajte si nič ujsť"
				subtitle="Prihláste sa na odber noviniek, aby ste sa dozvedeli o nových ponukách a výhodných výletoch ako prví."
			/>

			<form class="flex flex-col gap-3 w-full max-w-2xl">
				<input
					type="email"
					placeholder="Vaša e-mailová adresa"
					required
					class="grow px-4 py-3 border border-secondary rounded-full focus:outline-none focus:ring-2 focus:ring-tint w-full"
				/>
				<button type="submit" class="btn-primary whitespace-nowrap max-w-full">
					Prihlásiť sa
				</button>
			</form>
		</div>
	</section>
</Layout>
